// Firestore セキュリティルール
// Firebase コンソール → Firestore Database → ルール に貼り付けてください

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 商品: 誰でも読める。書き込みは管理者のみ（クライアントから直接書く運用）
    match /products/{productId} {
      allow read: if true;
      allow write: if request.auth != null;
      // ↑ 厳しくするなら：request.auth.token.admin == true などのカスタムクレームに変更
    }

    // 注文: 書き込みはサーバー（Admin SDK）のみ。読み取りは管理者のみ
    match /orders/{orderId} {
      allow read: if request.auth != null;
      allow write: if false; // クライアントからは書かせない（サーバー経由）
    }
  }
}
